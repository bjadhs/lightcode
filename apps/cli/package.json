{
  "name": "@lightcode/cli",
  "version": "0.0.1",
  "module": "src/index.tsx",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "bun --watch run src/index.tsx",
    "build": "bun build src/index.tsx --outdir dist --target bun --compile --outfile lightcode",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@lightcode/api-client": "workspace:*",
    "@lightcode/shared": "workspace:*",
    "@lightcode/tools": "workspace:*",
    "@opentui/core": "^0.2.1",
    "@opentui/react": "^0.2.1",
    "react": "^19.2.4",
    "react-router": "^7.15.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/react": "latest"
  }
}