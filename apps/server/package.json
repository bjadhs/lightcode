{
  "name": "@lightcode/server",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun --env-file=../../.env --watch run src/index.ts",
    "build": "bun build src/index.ts --outdir dist --target bun",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@lightcode/ai": "workspace:*",
    "@lightcode/database": "workspace:*",
    "@lightcode/shared": "workspace:*",
    "@lightcode/tools": "workspace:*",
    "hono": "latest"
  },
  "devDependencies": {
    "@types/bun": "latest"
  }
}
